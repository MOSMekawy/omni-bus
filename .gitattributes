# Normalize all text files to LF in the repository.
# Windows checkouts can still have CRLF in working trees via core.autocrlf.
* text=auto eol=lf

# Force LF for files where it matters
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.sh        text eol=lf

# Binary
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
