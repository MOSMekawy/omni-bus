		"@types/node": "^22.0.0",
		"@types/uuid": "^9.0.8",
		"cross-env": "^7.0.3",
		"jest": "^29.7.0",
		"testcontainers": "^10.13.0",
		"ts-jest": "^29.1.2",
		"typescript": "^5.5.0"
	}
}